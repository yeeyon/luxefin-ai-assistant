# Required: embed token from chatbot dashboard (Settings > Embed Tokens)
NEXT_PUBLIC_AI_EMBED_TOKEN=your_embed_token_here

# Required for production: your deployed URL (must match allowed domains on embed token)
NEXT_PUBLIC_AI_ORIGIN=https://your-app.vercel.app

# Optional: override chatbot API host (default: https://chatbot.therelah.com)
NEXT_PUBLIC_AI_CHATBOT_URL=https://chatbot.therelah.com
